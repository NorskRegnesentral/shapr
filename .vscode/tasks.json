{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "R: Run all tests (snapshot-safe)",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R --run-tests",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Run and review snapshots (snapshot-safe)",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R --run-tests --review-md --review-rds",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Run current test file (snapshot-safe)",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R --run-tests --file '${file}'",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Review RDS snapshots",
      "detail": "Reviews only changed *.rds snapshots with waldo diffs and an Enter prompt between files.",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R --review-rds",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Run all tests (devtools::test)",
      "type": "shell",
      "command": "Rscript -e \"devtools::test()\"",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Run tests for current file (devtools)",
      "type": "shell",
      "command": "Rscript -e \"devtools::test_active_file('${file}')\"",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Review MD snapshots",
      "detail": "Opens the testthat snapshot review app for changed *.md snapshots only.",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R --review-md",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Inspect snapshot diffs (agent helper)",
      "detail": "Agent-oriented read-only helper: prints terminal diffs for every changed *.rds and *.md snapshot.",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Inspect RDS snapshot diffs (agent helper)",
      "detail": "Agent-oriented read-only helper: prints waldo::compare() diffs for changed *.rds snapshots only.",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R --rds",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Inspect MD snapshot diffs (agent helper)",
      "detail": "Agent-oriented read-only helper: prints waldo::compare() diffs for changed *.md snapshots only.",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R --md",
