    {
      "label": "R: Accept all new snapshots",
      "detail": "Replaces every stored snapshot with the new version. Run only after reviewing diffs.",
      "type": "shell",
      "command": "Rscript dev/snapshot-diff.R --accept",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "R: Rebuild long-running vignettes",
